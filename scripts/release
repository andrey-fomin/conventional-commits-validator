#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/release <version>

Example:
  scripts/release 0.2.0

This script:
  1. Verifies the git working tree is clean
  2. Verifies you are on the main branch
  3. Verifies Cargo.toml already contains the requested version
  4. Creates a matching git tag (v<version>)

After running this script, push manually:
  git push origin main
  git push origin v<version>

Prerequisites:
  - Ensure Cargo.toml version matches the version you want to release
  - Ensure your working tree is clean (no uncommitted changes)
  - Ensure you are on the main branch
EOF
}

if [[ $# -eq 1 && ( "$1" == "--help" || "$1" == "-h" ) ]]; then
  usage
  exit 0
fi

if [[ $# -ne 1 ]]; then
  usage
  exit 1
fi

version="$1"

if [[ "$version" == v* ]]; then
  printf 'Error: pass the version without a leading v, for example 0.2.0\n' >&2
  exit 1
fi

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
  printf "Error: version '%s' is not a valid SemVer value\n" "$version" >&2
  exit 1
fi

cd "$(git rev-parse --show-toplevel)"

if [[ -n "$(git status --short)" ]]; then
  printf 'Error: git working tree is not clean\n' >&2
  exit 1
fi

current_branch=$(git branch --show-current)
if [[ -z "$current_branch" ]]; then
  printf 'Error: cannot release from detached HEAD\n' >&2
  exit 1
fi

if [[ "$current_branch" != "main" ]]; then
  printf 'Error: releases must be created from main branch (current: %s)\n' "$current_branch" >&2
  exit 1
fi

cargo_version=$(python3 - <<'PY'
from pathlib import Path
import re
import sys

path = Path("Cargo.toml")
content = path.read_text()
match = re.search(r'^version\s*=\s*"([^"]+)"', content, flags=re.MULTILINE)
if not match:
    raise SystemExit("Error: could not find version in Cargo.toml")
print(match.group(1))
PY
)

if [[ "$cargo_version" != "$version" ]]; then
  printf 'Error: Cargo.toml version is %s, but requested version is %s\n' "$cargo_version" "$version" >&2
  printf '       Update Cargo.toml to version %s before running this script\n' "$version" >&2
  exit 1
fi

tag="v$version"

if git rev-parse --verify --quiet "$tag" >/dev/null 2>&1; then
  printf "Error: git tag '%s' already exists locally\n" "$tag" >&2
  exit 1
fi

if git ls-remote --tags origin 2>/dev/null | grep -q "refs/tags/${tag}$"; then
  printf "Error: git tag '%s' already exists on origin\n" "$tag" >&2
  exit 1
fi

git tag "$tag"

printf "Created local tag %s\n" "$tag"
printf "When ready, push with:\n"
printf "  git push origin %s\n" "$current_branch"
printf "  git push origin %s\n" "$tag"